<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Datos de Transferencia</title>

<style>
body {
font-family: Arial;
text-align: center;
margin: 0;
padding: 20px;
background: black;
}

img {
max-width: 100%;
border-radius: 12px;
margin-bottom: 20px;
}

button {
padding:14px 18px;
font-size:16px;
border:none;
border-radius:10px;
color:white;
margin:5px;
min-width:120px;
cursor:pointer;
}

.clabe { background:#4CAF50; }
.titular { background:#2196F3; }
.cuenta { background:#FF9800; }

</style>
</head>

<body>

<img src="https://i.imgur.com/ASsuQSw.png">

<div>
<button class="clabe" onclick="copyClabe()">Copiar CLABE</button>
<button class="titular" onclick="copyTitular()">Copiar Titular</button>
<button class="cuenta" onclick="copyCuenta()">Copiar Cuenta</button>
</div>

<script>
function copyClabe(){
navigator.clipboard.writeText("014180605314295566");
alert("CLABE copiada");
}
function copyTitular(){
navigator.clipboard.writeText("Silvia Angelica Del Rey Flores");
alert("Titular copiado");
}
function copyCuenta(){
navigator.clipboard.writeText("60531429556");
alert("Cuenta copiada");
}
</script>

</body>
</html>
